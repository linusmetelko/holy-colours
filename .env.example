# Domain, unter der Traefik die App ausliefert.
HOLY_COLOURS_DOMAIN=colours.example.com

# Bestehendes externes Docker-Netzwerk deines Traefik-Containers.
TRAEFIK_NETWORK=traefik

# Passe diese Werte an deine bestehende Traefik-Konfiguration an.
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERTRESOLVER=letsencrypt

# Mit `htpasswd -nbB admin 'dein-passwort'` erzeugen.
# Wichtig: Wenn der Hash direkt hier eingetragen wird, Dollarzeichen als $$ schreiben.
HOLY_COLOURS_BASIC_AUTH=admin:$$2y$$05$$replace-this-with-a-real-bcrypt-hash
